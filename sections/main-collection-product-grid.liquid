function startAutoplayForSliders() {
    document.querySelectorAll('.mw_blurb_slider').forEach(slider => {
      const sliderElement = slider.querySelector('[id^="Slider-"]');
      if (sliderElement && !slider.classList.contains('slideshow-component')) {
        let currentIndex = 0;
        const slideInterval = setInterval(() => {
          const slides = sliderElement.querySelectorAll('.collection_blurb_slide');
          if (slides.length > 0) {
            currentIndex = (currentIndex + 1) % slides.length;
            sliderElement.scrollTo({
              left: slides[currentIndex].offsetLeft,
              behavior: 'smooth'
            });
          }
        }, 7000); // Set autoplay speed in milliseconds (e.g., 5000 for 5 seconds)
        // Optional: Pause on hover
        slider.addEventListener('mouseenter', () => clearInterval(slideInterval));
        slider.addEventListener('mouseleave', () => startAutoplayForSliders());
      }
    });
}
document.addEventListener('DOMContentLoaded', startAutoplayForSliders);
